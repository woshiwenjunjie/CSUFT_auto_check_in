# ═══════════════════════════════════════════════════════════
# SCF 环境变量模板 — 复制后去掉注释即可使用
# 在 SCF 控制台 → 函数配置 → 环境变量 中设置
# 全部敏感字段勾选「加密」存储
# ═══════════════════════════════════════════════════════════

# ── 多用户模式 ──
CHECKIN_PROFILES=USER_1,USER_2

CHECKIN_OPENID_USER_1=你的OpenID（o开头约28位）
CHECKIN_USERNAME_USER_1=你的学号
# CHECKIN_PASSWORD_USER_1=你的密码（免密码账号可不设）

CHECKIN_OPENID_USER_2=第二个账号的OpenID
CHECKIN_USERNAME_USER_2=第二个账号的学号
# CHECKIN_PASSWORD_USER_2=第二个账号的密码

# ── 单用户回退（不设 CHECKIN_PROFILES 时生效） ──
# CHECKIN_OPENID=你的OpenID
# CHECKIN_USERNAME=你的学号
# CHECKIN_PASSWORD=你的密码

# ── 通用 ──
# CHECKIN_TASK_ID=任务ID（不设则自动获取最新任务）
# SERVERCHAN_KEY=SCT1234567890abcdef（微信推送通知，可选）
