# ═══════════════════════════════════════════════════════════
# GitHub Actions / CLI 环境变量模板
# 复制为 .env 或直接在 CI Secrets 中设置
# ═══════════════════════════════════════════════════════════

# ── 单用户打卡（必填） ──
CHECKIN_OPENID=o开头约28位
CHECKIN_USERNAME=2023XXXXXX
# CHECKIN_PASSWORD=你的密码（可选，CLI setup 向导也会提示）

# ── 打卡任务 ──
# CHECKIN_TASK_ID=任务ID（不设则自动获取）

# ── 微信通知（可选） ──
# SERVERCHAN_KEY=SCT1234567890abcdef

# ── Telegram 通知（可选） ──
# TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TG_CHAT_ID=123456789

# ── API 覆盖（通常不需要改） ──
# CHECKIN_BASE_URL=https://simp.csuft.edu.cn
# FLYSOURCE_CLIENT_ID=flysource_wise_wxapp
# FLYSOURCE_CLIENT_SECRET=DA788asdUDjnasd_flysource_wxappdsdadDAIUiuwqe
